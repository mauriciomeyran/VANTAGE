import sys, os, argparse, json, time
from pathlib import Path
from datetime import datetime, timezone

_SCRIPT_DIR = Path(__file__).resolve().parent
_VENV_SITE  = _SCRIPT_DIR.parent / ".venv" / "lib"
for _p in _VENV_SITE.glob("python3*/site-packages"):
    sys.path.insert(0, str(_p)); break

_ENV_PATH = _SCRIPT_DIR.parent / "config" / "layer_1.env"
if _ENV_PATH.exists():
    with open(_ENV_PATH) as _f:
        for _line in _f:
            _line = _line.strip()
            if _line and not _line.startswith("#") and "=" in _line:
                _k, _, _v = _line.partition("=")
                os.environ.setdefault(_k.strip(), _v.strip().strip('"').strip("'"))

NOTION_TOKEN = os.environ.get("NOTION_API_KEY") or os.environ.get("NOTION_TOKEN")
if not NOTION_TOKEN:
    print("❌ NOTION_TOKEN no encontrado"); sys.exit(1)

from notion_client import Client
import httpx

notion = Client(auth=NOTION_TOKEN, timeout_ms=60000)
HTTP = httpx.Client(timeout=60.0)
HEADERS = {
    "Authorization": f"Bearer {NOTION_TOKEN}",
    "Notion-Version": "2022-06-28",
}

BASE_DIR = Path.home() / "Documents" / "04-Vantage_CV" / "- Documentación" / "v8.5"
DOCS = {
    "kernel": {"notion_id": "377938be-fc42-805e-a408-c9ae518d4fe7", "local_file": BASE_DIR / "Kernel v8.5.md", "label": "TECHNICAL KERNEL"},
    "system_prompt": {"notion_id": "37b938be-fc42-8001-9b9b-fcf81130d274", "local_file": BASE_DIR / "System Prompt v8.5.md", "label": "SYSTEM PROMPT"},
    "career_canon": {"notion_id": "377938be-fc42-8089-93f2-f52dbd2dec6c", "local_file": BASE_DIR / "Career Canon v8.5.md", "label": "CAREER CANON"},
    "manual": {"notion_id": "372938be-fc42-8050-9a67-e40857d7806e", "local_file": BASE_DIR / "Manual v8.5.md", "label": "MANUAL DE USUARIO"},
}
def _rich_text(rt_list: list) -> str:
    if not rt_list: return ""
    return "".join(r.get("plain_text", "") for r in rt_list)

def _block_to_md(block: dict) -> str:
    bt = block.get("type", "")
    b = block.get(bt) or {}  # ← garantiza dict, nunca None
    
    rt = lambda key="rich_text": _rich_text(b.get(key) or [])

    if bt == "paragraph": 
        return rt() + "\n"
    if bt in ("heading_1", "heading_2", "heading_3"):
        level = {"heading_1": "#", "heading_2": "##", "heading_3": "###"}[bt]
        return f"{level} {rt()}\n"
    if bt == "bulleted_list_item": 
        return f"- {rt()}\n"
    if bt == "numbered_list_item": 
        return f"1. {rt()}\n"
    if bt == "to_do":
        check = "x" if b.get("checked") else " "
        return f"- [{check}] {rt()}\n"
    if bt == "code":
        return f"```{b.get('language','')}\n{rt()}\n```\n"
    if bt == "quote": 
        return f"> {rt()}\n"
    if bt == "divider": 
        return "---\n"
    if bt == "callout":
        icon = b.get("icon") or {}  # ← FIX: icon puede ser None
        emoji = icon.get("emoji", "") if isinstance(icon, dict) else ""
        prefix = f"{emoji} " if emoji else ""
        return f"> {prefix}{rt()}\n"
    if bt == "toggle": 
        return f"**{rt()}**\n"
    if bt == "child_page": 
        return f"[{b.get('title','')}]\n"
    return ""

def safe_list_children(block_id: str, cursor: str=None) -> dict | None:
    """Reemplazo robusto de notion.blocks.children.list"""
    url = f"https://api.notion.com/v1/blocks/{block_id}/children"
    params = {"page_size": 100}
    if cursor: params["start_cursor"] = cursor
    
    for attempt in range(3):
        try:
            r = HTTP.get(url, headers=HEADERS, params=params)
            if r.status_code == 200:
                return r.json()
            print(f"      ⚠️ HTTP {r.status_code}: {r.text[:150]}")
        except Exception as e:
            print(f"      ⚠️ Intento {attempt+1}/3: {e}")
        time.sleep(1.5 * (attempt+1))
    return None

def fetch_notion_as_md(page_id: str) -> tuple[str|None, datetime]:
    try:
        meta = notion.pages.retrieve(page_id)
        last_edited = datetime.fromisoformat(meta["last_edited_time"].replace("Z","+00:00"))
        title = ""
        for prop in meta.get("properties",{}).values():
            if prop and prop.get("type")=="title":
                title = _rich_text(prop.get("title",[])); break
        
        lines = [f"# {title}\n\n"] if title else []
        cursor, total = None, 0
        
        while True:
            data = safe_list_children(page_id, cursor)
            if data is None:
                print(f"    ❌ FALLO al leer bloques")
                return None, last_edited
            
            for block in data.get("results",[]):
                md = _block_to_md(block)
                if md: lines.append(md)
                total += 1
                
            if not data.get("has_more"): break
            cursor = data.get("next_cursor")
        
        print(f"    ✅ {total} bloques leídos")
        return "".join(lines), last_edited
        
    except Exception as e:
        print(f"    ❌ EXCEPTION: {e}")
        import traceback; traceback.print_exc()
        return None, datetime.now(timezone.utc)

def push_local_to_notion(page_id: str, md_path: Path) -> None:
    content = md_path.read_text(encoding="utf-8")
    # limpiar con safe_list
    cursor = None
    while True:
        data = safe_list_children(page_id, cursor)
        if not data: break
        for block in data.get("results",[]):
            try: notion.blocks.delete(block["id"])
            except: pass
        if not data.get("has_more"): break
        cursor = data.get("next_cursor")
    
    # ... resto de tu código de push sin cambios ...
    lines = content.splitlines(); blocks=[]; i=0
    while i < len(lines):
        line = lines[i]
        if line.startswith("```"):
            lang=line[3:].strip(); code=[]; i+=1
            while i < len(lines) and not lines[i].startswith("```"): code.append(lines[i]); i+=1
            blocks.append({"object":"block","type":"code","code":{"language":lang or "plain text","rich_text":[{"type":"text","text":{"content":"\n".join(code)}}]}})
        elif line.startswith("### "): blocks.append({"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":line[4:]}}]}})
        elif line.startswith("## "): blocks.append({"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":line[3:]}}]}})
        elif line.startswith("# "): blocks.append({"object":"block","type":"heading_1","heading_1":{"rich_text":[{"type":"text","text":{"content":line[2:]}}]}})
        elif line.startswith("- [x] ") or line.startswith("- [X] "): blocks.append({"object":"block","type":"to_do","to_do":{"checked":True,"rich_text":[{"type":"text","text":{"content":line[6:]}}]}})
        elif line.startswith("- [ ] "): blocks.append({"object":"block","type":"to_do","to_do":{"checked":False,"rich_text":[{"type":"text","text":{"content":line[6:]}}]}})
        elif line.startswith("- "): blocks.append({"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":line[2:]}}]}})
        elif line.startswith("> "): blocks.append({"object":"block","type":"quote","quote":{"rich_text":[{"type":"text","text":{"content":line[2:]}}]}})
        elif line.startswith("---"): blocks.append({"object":"block","type":"divider","divider":{}})
        elif line.strip(): blocks.append({"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":line}}]}})
        else: blocks.append({"object":"block","type":"paragraph","paragraph":{"rich_text":[]}})
        i+=1
    for c in range(0,len(blocks),100): notion.blocks.children.append(block_id=page_id, children=blocks[c:c+100])

def sync_doc(key, doc, direction, dry_run):
    label=doc["label"]; local_path=doc["local_file"]; notion_id=doc["notion_id"]
    result={"key":key,"label":label,"action":None,"status":"ok","detail":""}
    
    notion_md, notion_ts = fetch_notion_as_md(notion_id)
    if notion_md is None:
        result["action"]="error"; result["status"]="error"; result["detail"]="Fetch Notion falló (ver log arriba)"; return result
    
    local_mtime = datetime.fromtimestamp(local_path.stat().st_mtime, tz=timezone.utc) if local_path.exists() else datetime.min.replace(tzinfo=timezone.utc)
    local_md = local_path.read_text(encoding="utf-8") if local_path.exists() else ""
    
    if direction=="notion": winner="notion"
    elif direction=="local": winner="local"
    else:
        if not local_path.exists() or notion_md.strip()==local_md.strip(): winner=None
        else: winner="notion" if notion_ts>=local_mtime else "local"
    
    if winner is None:
        result["action"]="in_sync"; return result
    
    if winner=="notion":
        result["action"]="notion→local"
        if not notion_md.strip():
            result["status"]="error"; result["detail"]="PROTEGIDO: Notion vacío"; return result
        if not dry_run:
            local_path.parent.mkdir(parents=True, exist_ok=True)
            local_path.write_text(notion_md, encoding="utf-8")
    else:
        result["action"]="local→notion"
        if not dry_run: push_local_to_notion(notion_id, local_path)
    return result

# CLI (sin cambios)
def main():
    parser=argparse.ArgumentParser(description="vsync_doc v8.5.1")
    parser.add_argument("--direction",choices=["notion","local","auto"],default="auto")
    parser.add_argument("--dry-run",action="store_true")
    parser.add_argument("--doc",choices=list(DOCS.keys()))
    parser.add_argument("--json",action="store_true")
    args=parser.parse_args()
    targets={args.doc:DOCS[args.doc]} if args.doc else DOCS
    results=[]
    for k,d in targets.items():
        try: r=sync_doc(k,d,args.direction,args.dry_run)
        except Exception as e: r={"key":k,"label":d["label"],"action":"error","status":"error","detail":str(e)}
        results.append(r)
        if not args.json: print(f"  {r['action']}  {r['label']:<30} {r['detail']}")
    if args.json: print(json.dumps(results,indent=2))

if __name__ == "__main__": main()