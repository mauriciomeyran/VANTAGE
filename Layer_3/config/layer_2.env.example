# Copiar a layer_2.env y completar (Gmail · Groq · Notion)
GMAIL_USER=
GMAIL_APP_PASS=
GMAIL_LABEL=.Jobs
GROQ_API_KEY=
# 8b-instant = más cuota gratuita; 70b = mejor calidad pero rate limit frecuente
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MIN_DELAY_SEC=12
GROQ_MAX_RETRIES=8
GROQ_MAX_EMAILS_PER_RUN=5
NOTION_TOKEN=
NOTION_DB_ID=
